@using Elsa.Studio.Dashboard.Components
@using Elsa.Studio.Dashboard.Models
@using Elsa.Studio.Dashboard.Services
@using Elsa.Studio.Diagnostics.StructuredLogs.Contracts
@inherits DashboardAsyncWidgetBase<RecentStructuredLogsResult>
@inject IStructuredLogService StructuredLogService

@if (Loading && Value == null)
{
    <MudSkeleton Height="220px" Animation="Animation.Wave" />
}
else
{
    <div class="dashboard-log-card">
        <MudPaper Outlined="true" Elevation="0" Class="dashboard-panel dashboard-section dashboard-log-panel" Style="@DashboardStyles.Panel">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="dashboard-section-header" Style="@DashboardStyles.SectionHeader">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="flex-wrap">
                    <MudText Typo="Typo.subtitle1">Structured logs</MudText>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@EventCountColor">@EventCountLabel</MudChip>
                </MudStack>
                <MudButton Href="@DashboardNavigationTargetMapper.StructuredLogs" Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.OpenInNew">Open logs</MudButton>
            </MudStack>

            @if (Loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
            }

            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@Message</MudAlert>
            }
            else if (Result.Items.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No structured log entries in this range.</MudAlert>
            }
            else
            {
                @if (Result.DroppedEvents > 0)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">@DashboardMetricFormatter.Count(Result.DroppedEvents) structured log entries were dropped in this range.</MudAlert>
                }

                <div class="dashboard-log-list" role="list" aria-label="Recent structured log entries">
                    @foreach (var logEvent in Result.Items)
                    {
                        <article class="dashboard-log-row dashboard-structured-log-row" role="listitem">
                            <MudText Typo="Typo.caption" Class="dashboard-log-time">@FormatTimestamp(logEvent.Timestamp)</MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@LevelColor(logEvent.Level)">@LevelLabel(logEvent.Level)</MudChip>
                            <MudText Typo="Typo.caption" Class="dashboard-log-source" title="@logEvent.Category">@CategoryLabel(logEvent.Category)</MudText>
                            <MudText Typo="Typo.body2" Class="dashboard-log-message" title="@MessageTitle(logEvent)">
                                @logEvent.Message
                                @if (logEvent.Exception != null)
                                {
                                    <span class="dashboard-log-exception">@ExceptionLabel(logEvent.Exception)</span>
                                }
                            </MudText>
                        </article>
                    }
                </div>
            }
        </MudPaper>
    </div>
}

@code {
    private const int RowCap = 12;

    private RecentStructuredLogsResult Result => Value ?? new();
    private string EventCountLabel => Result.Items.Count == 1 ? "1 entry" : $"{Result.Items.Count} entries";
    private Color EventCountColor => Result.Items.Count > 0 ? Color.Success : Color.Default;

    protected override Task<RecentStructuredLogsResult> LoadValueAsync(DashboardWidgetContext context, CancellationToken cancellationToken)
    {
        var range = DashboardRangeMapper.GetUtcRange(context.Range);
        return StructuredLogService.GetRecentAsync(new StructuredLogFilter
        {
            From = range.From,
            To = range.To,
            MinimumLevel = null
        }, RowCap, cancellationToken);
    }

    private static string FormatTimestamp(DateTimeOffset timestamp) => timestamp.ToLocalTime().ToString("HH:mm:ss");

    private static string LevelLabel(StructuredLogLevel level) => level switch
    {
        StructuredLogLevel.Information => "Info",
        StructuredLogLevel.Critical => "Crit",
        _ => level.ToString()
    };

    private static Color LevelColor(StructuredLogLevel level) => level switch
    {
        StructuredLogLevel.Critical or StructuredLogLevel.Error => Color.Error,
        StructuredLogLevel.Warning => Color.Warning,
        StructuredLogLevel.Information => Color.Info,
        _ => Color.Default
    };

    private static string CategoryLabel(string category)
    {
        if (string.IsNullOrWhiteSpace(category))
            return "category";

        var separatorIndex = category.LastIndexOf('.');
        return separatorIndex == -1 || separatorIndex == category.Length - 1 ? category : category[(separatorIndex + 1)..];
    }

    private static string MessageTitle(StructuredLogEvent logEvent)
    {
        if (logEvent.Exception == null)
            return logEvent.Message;

        return $"{logEvent.Message} {ExceptionLabel(logEvent.Exception)}";
    }

    private static string ExceptionLabel(StructuredLogException exception)
    {
        return string.IsNullOrWhiteSpace(exception.Message) ? exception.Type ?? "Exception" : exception.Message;
    }
}
