{
  "compilerOptions": {
    "outDir": "../wwwroot",
    "sourceMap": true,
    "noImplicitAny": false,
    "module": "ES2022",
    "target": "ES2022",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "./src/**/*"
  ]
}
