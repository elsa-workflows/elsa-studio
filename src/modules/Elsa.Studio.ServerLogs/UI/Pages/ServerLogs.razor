@page "/server-logs"
@inherits StudioComponentBase
@inject ILocalizer Localizer

<PageTitle>@Localizer["Server Logs"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="server-logs-page">
    <PageHeading Text="@Localizer["Server Logs"]" />

    <MudPaper Elevation="0" Outlined="true" Class="server-logs-toolbar">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="server-logs-toolbar-row">
            <span class="server-logs-status @StatusCssClass">
                <span class="server-logs-status-dot"></span>
                @StatusText
            </span>

            <span class="server-logs-count">@Rows.Count @Localizer["rows"]</span>

            @if (ViewState.LocalDroppedRows > 0)
            {
                <span class="server-logs-dropped">@ViewState.LocalDroppedRows @Localizer["discarded locally"]</span>
            }

            @if (BackendDroppedCount > 0)
            {
                <span class="server-logs-dropped">@BackendDroppedCount @Localizer["dropped upstream"]</span>
            }

            <MudSpacer />

            <MudTooltip Text="@PauseTooltip" Delay="500">
                <MudIconButton Icon="@PauseIcon" Size="Size.Small" OnClick="TogglePausedAsync" />
            </MudTooltip>

            <MudTooltip Text="@Localizer["Clear"]" Delay="500">
                <MudIconButton Icon="@Icons.Material.Outlined.DeleteSweep" Size="Size.Small" OnClick="ClearAsync" />
            </MudTooltip>

            <MudTooltip Text="@Localizer["Reconnect"]" Delay="500">
                <MudIconButton Icon="@Icons.Material.Outlined.Refresh" Size="Size.Small" OnClick="ReconnectAsync" />
            </MudTooltip>

            <MudTooltip Text="@Localizer["Auto scroll"]" Delay="500">
                <MudSwitch T="bool"
                           Value="@ViewState.AutoScroll"
                           Color="Color.Primary"
                           Label="@Localizer["Auto"]"
                           LabelPlacement="Placement.Start"
                           ValueChanged="SetAutoScrollAsync" />
            </MudTooltip>

            <MudTooltip Text="@Localizer["Wrap messages"]" Delay="500">
                <MudSwitch T="bool"
                           Value="@ViewState.WrapMessages"
                           Color="Color.Primary"
                           Label="@Localizer["Wrap"]"
                           LabelPlacement="Placement.Start"
                           ValueChanged="SetWrapMessagesAsync" />
            </MudTooltip>

            <MudTooltip Text="@Localizer["Compact rows"]" Delay="500">
                <MudSwitch T="bool"
                           Value="@ViewState.Compact"
                           Color="Color.Primary"
                           Label="@Localizer["Compact"]"
                           LabelPlacement="Placement.Start"
                           ValueChanged="SetCompactAsync" />
            </MudTooltip>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@ErrorMessage</MudAlert>
    }

    @if (IsLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-3" />
    }

    <section class="@LogSurfaceCssClass" id="@LogSurfaceId">
        @if (Rows.Count == 0 && !IsLoading)
        {
            <div class="server-logs-empty">@Localizer["No server logs received yet."]</div>
        }
        else
        {
            @foreach (var logEvent in Rows)
            {
                <article class="@RowCssClass(logEvent)">
                    <time class="server-log-time" title="@logEvent.Timestamp.ToString("O")">@FormatTimestamp(logEvent.Timestamp)</time>
                    <span class="@LevelCssClass(logEvent.Level)">@logEvent.Level</span>
                    <span class="server-log-source" title="@logEvent.SourceId">@Shorten(logEvent.SourceId, 28)</span>
                    <span class="server-log-category" title="@logEvent.Category">@Shorten(logEvent.Category, 64)</span>
                    <span class="server-log-message">@logEvent.Message</span>

                    @if (logEvent.Exception != null)
                    {
                        <pre class="server-log-exception">@logEvent.Exception.Type: @logEvent.Exception.Message
@logEvent.Exception.StackTrace</pre>
                    }
                </article>
            }
        }
    </section>
</MudContainer>
