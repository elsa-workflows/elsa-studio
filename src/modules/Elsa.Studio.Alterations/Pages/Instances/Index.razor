@page "/alterations/instances"
@using Elsa.Api.Client.Resources.WorkflowInstances.Enums
@using Elsa.Api.Client.Resources.WorkflowInstances.Models
@using Elsa.Api.Client.Resources.WorkflowInstances.Requests
@using Elsa.Studio.Workflows.Domain.Contracts
@inherits StudioComponentBase
@implements IDisposable
@inject IWorkflowInstanceService WorkflowInstanceService
@inject ILocalizer Localizer
@inject NavigationManager Nav

<PageTitle>@Localizer["Alterable instances"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.False">
    <PageHeading Text="@Localizer["Alterable instances"]" />

    <MudTable T="WorkflowInstanceSummary"
              ServerData="LoadAsync"
              Dense="true" Hover="true" Elevation="0"
              @ref="_table"
              RowStyle="cursor: pointer;"
              OnRowClick="OnRowClick">
        <ToolBarContent>
            <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                     Label="@Localizer["Actions"]"
                     Color="Color.Primary"
                     Variant="Variant.Filled"
                     Dense="true">
                <MudMenuItem Icon="@Icons.Material.Outlined.Refresh"
                             OnClick="ReloadTableAsync">
                    @Localizer["Refresh"]
                </MudMenuItem>
                <MudMenuItem Icon="@(_polling ? Icons.Material.Outlined.PauseCircle : Icons.Material.Outlined.Autorenew)"
                             OnClick="@(() => OnPollingChanged(!_polling))">
                    @(_polling ? Localizer["Pause polling"] : Localizer["Enable polling"])
                </MudMenuItem>
            </MudMenu>

            <MudSpacer />

            <MudTextField T="string"
                          Text="@_searchTerm"
                          Placeholder="@Localizer["Search by name or id"]"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          AdornmentIcon="@Icons.Material.Outlined.Search"
                          Adornment="Adornment.End"
                          Clearable="true"
                          DebounceInterval="500"
                          Immediate="true"
                          Class="me-3"
                          Style="height: 36.5px; width: 360px"
                          ValueChanged="OnSearchChanged" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@Localizer["Name"]</MudTh>
            <MudTh>@Localizer["Definition"]</MudTh>
            <MudTh>@Localizer["Version"]</MudTh>
            <MudTh>@Localizer["Sub-status"]</MudTh>
            <MudTh>@Localizer["Created"]</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@Localizer["Name"]">
                @(string.IsNullOrEmpty(context.Name) ? context.Id : context.Name)
            </MudTd>
            <MudTd DataLabel="@Localizer["Definition"]">
                <MudText Typo="Typo.body2" Style="font-family:var(--mud-typography-input-font-family,monospace);">
                    @context.DefinitionId
                </MudText>
            </MudTd>
            <MudTd DataLabel="@Localizer["Version"]">v@(context.Version)</MudTd>
            <MudTd DataLabel="@Localizer["Sub-status"]">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Color="@MapSubStatusColor(context.SubStatus)">
                    @context.SubStatus
                </MudChip>
            </MudTd>
            <MudTd DataLabel="@Localizer["Created"]">
                <MudText Typo="Typo.body2">@context.CreatedAt.ToLocalTime().ToString("g")</MudText>
            </MudTd>
            <MudTd Style="text-align:right">
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Outlined.Tune"
                           Href="@($"alterations/instances/{context.Id}")">
                    @Localizer["Alter"]
                </MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@Localizer["No running instances. Start a workflow that suspends or runs long enough to alter."]</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>@Localizer["Loading…"]</MudText>
        </LoadingContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private MudTable<WorkflowInstanceSummary>? _table;
    private string _searchTerm = "";
    private bool _polling = true;
    private Timer? _pollingTimer;

    protected override void OnInitialized() => StartPolling();

    private void StartPolling()
    {
        StopPolling();
        if (!_polling) return;
        _pollingTimer = new Timer(_ =>
        {
            _ = InvokeAsync(ReloadTableAsync);
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private void StopPolling()
    {
        _pollingTimer?.Dispose();
        _pollingTimer = null;
    }

    private void OnPollingChanged(bool value)
    {
        _polling = value;
        if (_polling) StartPolling(); else StopPolling();
    }

    private void OnSearchChanged(string value)
    {
        _searchTerm = value;
        _ = ReloadTableAsync();
    }

    private Task ReloadTableAsync() => _table?.ReloadServerData() ?? Task.CompletedTask;

    public void Dispose() => StopPolling();

    private async Task<TableData<WorkflowInstanceSummary>> LoadAsync(TableState state, CancellationToken ct)
    {
        try
        {
            var request = new ListWorkflowInstancesRequest
            {
                Page = state.Page,
                PageSize = state.PageSize,
                SearchTerm = string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
                // Only running instances can usefully be altered.
                Status = WorkflowStatus.Running,
                // Hide system workflows (e.g. Elsa.Alterations.ExecuteAlterationPlan).
                IsSystem = false,
            };

            var response = await WorkflowInstanceService.ListAsync(request, ct);
            if (response is null)
                return new TableData<WorkflowInstanceSummary> { Items = [], TotalItems = 0 };

            return new TableData<WorkflowInstanceSummary>
            {
                Items = response.Items,
                TotalItems = (int)response.TotalCount,
            };
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch
        {
            return new TableData<WorkflowInstanceSummary> { Items = [], TotalItems = 0 };
        }
    }

    private void OnRowClick(TableRowClickEventArgs<WorkflowInstanceSummary> args)
    {
        if (args.Item != null)
            Nav.NavigateTo($"alterations/instances/{args.Item.Id}");
    }

    private static Color MapSubStatusColor(WorkflowSubStatus s) => s switch
    {
        WorkflowSubStatus.Executing => Color.Info,
        WorkflowSubStatus.Suspended => Color.Warning,
        WorkflowSubStatus.Pending => Color.Default,
        WorkflowSubStatus.Faulted => Color.Error,
        _ => Color.Default,
    };
}
