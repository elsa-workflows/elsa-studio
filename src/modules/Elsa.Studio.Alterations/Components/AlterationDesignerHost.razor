@using System.Text.Json.Nodes
@using Elsa.Api.Client.Resources.WorkflowDefinitions.Models
@using Elsa.Api.Client.Resources.WorkflowInstances.Models
@using Elsa.Studio.Workflows.Shared.Components

<div class="elsa-alterations-host @(_panelCollapsed ? "is-panel-collapsed" : "")">
    <div class="elsa-alterations-toolbar">
        <MudIconButton Icon="@Icons.Material.Outlined.ArrowBack"
                       Href="alterations/instances"
                       Size="Size.Small"
                       title="@Localizer["Back to instances"]" />

        <div class="elsa-alterations-toolbar-title">
            <span class="label">@Localizer["Altering instance"]</span>
            <span class="name">
                @(string.IsNullOrEmpty(WorkflowInstance?.Name) ? WorkflowInstance?.Id : WorkflowInstance.Name)
            </span>
        </div>

        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@MapStatusColor()">
            @WorkflowInstance?.Status
        </MudChip>

        <div class="elsa-alterations-toolbar-spacer"></div>

        @if (Staging.Items.Count > 0)
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                     Icon="@Icons.Material.Outlined.Layers">
                @string.Format(Localizer["{0} staged"], Staging.Items.Count)
            </MudChip>
        }

        <MudIconButton Icon="@(_panelCollapsed ? Icons.Material.Outlined.ChevronLeft : Icons.Material.Outlined.ChevronRight)"
                       Size="Size.Small"
                       OnClick="@(() => _panelCollapsed = !_panelCollapsed)"
                       title="@(_panelCollapsed ? Localizer["Show panel"] : Localizer["Hide panel"])" />
    </div>

    <div class="elsa-alterations-canvas">
        @if (WorkflowDefinition != null && WorkflowInstance != null && FlowchartActivity != null)
        {
            <DiagramDesignerWrapper
                WorkflowDefinitionVersionId="@WorkflowDefinition.Id"
                Activity="@FlowchartActivity"
                IsReadOnly="true"
                WorkflowInstanceId="@WorkflowInstance.Id"
                ActivitySelected="OnDiagramActivitySelected" />
        }
        else
        {
            <div style="display:flex; align-items:center; justify-content:center; height:100%;">
                <MudProgressCircular Indeterminate="true" />
            </div>
        }
    </div>

    <AlterationSidePanel @ref="_sidePanel"
                         SelectedActivityId="@_selectedActivityId"
                         SelectedActivityName="@_selectedActivityName"
                         SelectedActivityType="@_selectedActivityType"
                         InstanceId="@WorkflowInstance?.Id"
                         InstanceName="@WorkflowInstance?.Name"
                         InstanceStatus="@WorkflowInstance?.Status.ToString()"
                         Variables="@_variables"
                         VariablesLoading="@_variablesLoading"
                         Collapsed="@_panelCollapsed"
                         Busy="@_busy"
                         QuickActionRequested="OnQuickActionAsync"
                         ModifyVariableRequested="OnModifyVariableShortcutAsync"
                         EditStagedRequested="OnEditStagedAsync"
                         DryRunRequested="OnDryRunAsync"
                         DiscardAllRequested="OnDiscardAllAsync"
                         SubmitRequested="OnSubmitAsync" />
</div>
