@using Elsa.Api.Client.Resources.WorkflowInstances.Models
@implements IDisposable
@inject IAlterationStagingService Staging
@inject IAlterationCatalog Catalog
@inject ILocalizer Localizer

<div class="elsa-alt-bottom @(Collapsed ? "is-collapsed" : "")">
    <div class="elsa-alt-bottom-tabbar">
        <button type="button" class="@TabClass(Tab.Inspect)" @onclick="() => SetTab(Tab.Inspect)">
            <MudIcon Icon="@Icons.Material.Outlined.Adjust" Size="Size.Small" />
            <span>@Localizer["Inspect"]</span>
            @if (HasSelectedActivity)
            {
                <span class="dot" title="@Localizer["Activity selected"]"></span>
            }
        </button>
        <button type="button" class="@TabClass(Tab.Variables)" @onclick="() => SetTab(Tab.Variables)">
            <MudIcon Icon="@Icons.Material.Outlined.DataObject" Size="Size.Small" />
            <span>@Localizer["Variables"]</span>
            @if (Variables is { Count: > 0 })
            {
                <span class="badge">@Variables.Count</span>
            }
        </button>
        <button type="button" class="@TabClass(Tab.Staged)" @onclick="() => SetTab(Tab.Staged)">
            <MudIcon Icon="@Icons.Material.Outlined.Layers" Size="Size.Small" />
            <span>@Localizer["Staged"]</span>
            @if (Staging.Items.Count > 0)
            {
                <span class="badge primary">@Staging.Items.Count</span>
            }
        </button>

        <div class="elsa-alt-bottom-tabbar-spacer"></div>

        <MudIconButton Icon="@(Collapsed ? Icons.Material.Outlined.UnfoldMore : Icons.Material.Outlined.UnfoldLess)"
                       Size="Size.Small"
                       OnClick="@(() => OnCollapseToggle.InvokeAsync(!Collapsed))"
                       title="@(Collapsed ? Localizer["Expand"] : Localizer["Collapse"])" />
    </div>

    @if (!Collapsed)
    {
        <div class="elsa-alt-bottom-content">
            @switch (_activeTab)
            {
                case Tab.Inspect:
                    @RenderInspect()
                    break;
                case Tab.Variables:
                    @RenderVariables()
                    break;
                case Tab.Staged:
                    @RenderStaged()
                    break;
            }
        </div>
    }
</div>

@code {
    public enum Tab { Inspect, Variables, Staged }

    [Parameter] public string? SelectedActivityId { get; set; }
    [Parameter] public string? SelectedActivityName { get; set; }
    [Parameter] public string? SelectedActivityType { get; set; }

    /// <summary>The instance's variables, fetched once by the host.</summary>
    [Parameter] public IReadOnlyList<ResolvedVariable>? Variables { get; set; }

    /// <summary>True while the host is reloading variables.</summary>
    [Parameter] public bool VariablesLoading { get; set; }

    [Parameter] public bool Collapsed { get; set; }
    [Parameter] public EventCallback<bool> OnCollapseToggle { get; set; }

    /// <summary>Fired when the user clicks a quick-action button — host stages it.</summary>
    [Parameter] public EventCallback<AlterationDescriptor> QuickActionRequested { get; set; }

    /// <summary>Fired when the user clicks Modify on a variable row — host opens the
    /// ModifyVariable dialog with the variable id pre-filled.</summary>
    [Parameter] public EventCallback<ResolvedVariable> ModifyVariableRequested { get; set; }

    /// <summary>Fired when the user clicks Edit on a staged item.</summary>
    [Parameter] public EventCallback<StagedAlteration> EditStagedRequested { get; set; }

    private Tab _activeTab = Tab.Inspect;
    private IReadOnlyList<AlterationDescriptor>? _descriptors;

    private bool HasSelectedActivity => !string.IsNullOrEmpty(SelectedActivityId);

    protected override async Task OnInitializedAsync()
    {
        Staging.Changed += HandleStagingChanged;
        _descriptors = await Catalog.ListAsync();
    }

    public void Dispose()
    {
        Staging.Changed -= HandleStagingChanged;
    }

    private void HandleStagingChanged() => InvokeAsync(StateHasChanged);

    private void SetTab(Tab t) => _activeTab = t;

    private string TabClass(Tab t) => "elsa-alt-bottom-tab" + (_activeTab == t ? " is-active" : "");

    // ------------------------------------------------------------------------
    // Inspect tab — selected activity (when any) + always-available whole-instance
    // ------------------------------------------------------------------------
    private RenderFragment RenderInspect() => __builder =>
    {
        var activityActions = _descriptors?.Where(d => d.Target == AlterationTargetKind.Activity).ToList() ?? new();
        var instanceActions = _descriptors?.Where(d => d.Target != AlterationTargetKind.Activity).ToList() ?? new();

        <div class="elsa-alt-inspect">
            <section class="elsa-alt-inspect-section">
                <div class="elsa-alt-inspect-header">
                    <MudIcon Icon="@Icons.Material.Outlined.Adjust" Size="Size.Small" Color="Color.Primary" />
                    <h6>@Localizer["Selected activity"]</h6>
                </div>

                @if (HasSelectedActivity)
                {
                    <dl class="elsa-alt-kv">
                        <dt>@Localizer["Name"]</dt>
                        <dd>@SelectedActivityName</dd>
                        <dt>@Localizer["Id"]</dt>
                        <dd><code>@SelectedActivityId</code></dd>
                        @if (!string.IsNullOrEmpty(SelectedActivityType))
                        {
                            <dt>@Localizer["Type"]</dt>
                            <dd><code>@SelectedActivityType</code></dd>
                        }
                    </dl>

                    <div class="elsa-alt-actions">
                        @foreach (var d in activityActions)
                        {
                            <button type="button" class="elsa-alt-action-btn"
                                    style="@($"--accent: {ResolveAccent(d.Color)};")"
                                    title="@d.Description"
                                    @onclick="@(() => OnQuickAction(d))">
                                <MudIcon Icon="@d.Icon" Color="@MapColor(d.Color)" Size="Size.Small" />
                                <span>@d.DisplayName</span>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="elsa-alt-inspect-empty">
                        <MudIcon Icon="@Icons.Material.Outlined.TouchApp" Size="Size.Medium" />
                        <span>@Localizer["Click an activity in the diagram to inspect it and stage activity-scoped alterations."]</span>
                    </div>
                }
            </section>

            <section class="elsa-alt-inspect-section">
                <div class="elsa-alt-inspect-header">
                    <MudIcon Icon="@Icons.Material.Outlined.AllInclusive" Size="Size.Small" />
                    <h6>@Localizer["Whole instance"]</h6>
                </div>

                <div class="elsa-alt-actions">
                    @foreach (var d in instanceActions)
                    {
                        <button type="button" class="elsa-alt-action-btn"
                                style="@($"--accent: {ResolveAccent(d.Color)};")"
                                title="@d.Description"
                                @onclick="@(() => OnQuickAction(d))">
                            <MudIcon Icon="@d.Icon" Color="@MapColor(d.Color)" Size="Size.Small" />
                            <span>@d.DisplayName</span>
                            @if (d.ConfigFields.Count > 0)
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.Settings" Size="Size.Small"
                                         Class="ml-auto mud-text-secondary" />
                            }
                        </button>
                    }
                </div>
            </section>
        </div>
    };

    // ------------------------------------------------------------------------
    // Variables tab — each row has a Modify button that pre-fills variableId
    // ------------------------------------------------------------------------
    private RenderFragment RenderVariables() => __builder =>
    {
        <div class="elsa-alt-variables">
            @if (VariablesLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (Variables is null || Variables.Count == 0)
            {
                <div class="elsa-alt-inspect-empty">
                    <MudIcon Icon="@Icons.Material.Outlined.DataObject" Size="Size.Medium" />
                    <span>@Localizer["No variables on this instance."]</span>
                </div>
            }
            else
            {
                <table class="elsa-alt-var-table">
                    <thead>
                        <tr>
                            <th>@Localizer["Name"]</th>
                            <th>@Localizer["Value"]</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Variables)
                        {
                            <tr>
                                <td><strong>@v.Name</strong></td>
                                <td><code class="elsa-alt-var-value">@FormatValue(v.Value)</code></td>
                                <td style="text-align:right">
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                               StartIcon="@Icons.Material.Outlined.Edit"
                                               OnClick="@(() => OnModifyVariable(v))">
                                        @Localizer["Modify"]
                                    </MudButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    };

    // ------------------------------------------------------------------------
    // Staged tab — the alterations the user has queued up
    // ------------------------------------------------------------------------
    private RenderFragment RenderStaged() => __builder =>
    {
        <div class="elsa-alt-staged">
            @if (Staging.Items.Count == 0)
            {
                <div class="elsa-alt-inspect-empty">
                    <MudIcon Icon="@Icons.Material.Outlined.Layers" Size="Size.Medium" />
                    <span>@Localizer["Nothing staged yet."]</span>
                </div>
            }
            else
            {
                <div class="elsa-alt-staged-grid">
                    @foreach (var item in Staging.Items)
                    {
                        <div class="elsa-alt-staged-card" style="@($"--accent: {ResolveAccent(item.Descriptor.Color)};")">
                            <div class="header">
                                <MudIcon Icon="@item.Descriptor.Icon" Size="Size.Small" Color="@MapColor(item.Descriptor.Color)" />
                                <span>@item.Descriptor.DisplayName</span>
                                <MudSpacer />
                                @if (item.Descriptor.ConfigFields.Count > 0)
                                {
                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small"
                                                   OnClick="@(() => OnEditStaged(item))" />
                                }
                                <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                                               OnClick="@(() => Staging.Remove(item.Id))" />
                            </div>
                            <div class="target">
                                <MudIcon Icon="@TargetIcon(item.Descriptor.Target)" Size="Size.Small" />
                                @TargetText(item)
                            </div>
                            @{ var summary = item.SummariseConfig(); }
                            @if (!string.IsNullOrEmpty(summary))
                            {
                                <div class="config">@summary</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    };

    // ------------------------------------------------------------------------
    // Helpers
    // ------------------------------------------------------------------------
    private async Task OnQuickAction(AlterationDescriptor d)
    {
        if (QuickActionRequested.HasDelegate) await QuickActionRequested.InvokeAsync(d);
        // Auto-switch to Staged so the user can see the result land.
        if (Staging.Items.Any()) _activeTab = Tab.Staged;
    }

    private async Task OnModifyVariable(ResolvedVariable v)
    {
        if (ModifyVariableRequested.HasDelegate) await ModifyVariableRequested.InvokeAsync(v);
    }

    private async Task OnEditStaged(StagedAlteration item)
    {
        if (EditStagedRequested.HasDelegate) await EditStagedRequested.InvokeAsync(item);
    }

    private string TargetText(StagedAlteration item) => item.Descriptor.Target switch
    {
        AlterationTargetKind.Activity when !string.IsNullOrEmpty(item.TargetActivityId)
            => item.TargetActivityDisplayName ?? item.TargetActivityId,
        AlterationTargetKind.Activity => Localizer["No activity"],
        AlterationTargetKind.Variable => Localizer["Variable scope"],
        _ => Localizer["Whole instance"],
    };

    private static string TargetIcon(AlterationTargetKind kind) => kind switch
    {
        AlterationTargetKind.Activity => Icons.Material.Outlined.Adjust,
        AlterationTargetKind.Variable => Icons.Material.Outlined.DataObject,
        _ => Icons.Material.Outlined.AllInclusive,
    };

    private static Color MapColor(string? c) => c switch
    {
        "error" => Color.Error,
        "warning" => Color.Warning,
        "info" => Color.Info,
        "primary" => Color.Primary,
        "secondary" => Color.Secondary,
        _ => Color.Default,
    };

    private static string ResolveAccent(string? c) => c switch
    {
        "error" => "var(--mud-palette-error)",
        "warning" => "var(--mud-palette-warning)",
        "info" => "var(--mud-palette-info)",
        "primary" => "var(--mud-palette-primary)",
        "secondary" => "var(--mud-palette-secondary)",
        _ => "var(--mud-palette-primary)",
    };

    private static string FormatValue(object? raw)
    {
        if (raw is null) return "null";
        var s = raw.ToString() ?? "";
        return s.Length <= 80 ? s : s[..80] + "…";
    }
}
