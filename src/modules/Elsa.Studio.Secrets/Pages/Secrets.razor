@page "/security/secrets"
@using Elsa.Studio.Contracts
@using Elsa.Studio.Secrets.Client
@using Elsa.Studio.Secrets.Components
@inject IBackendApiClientProvider ApiClientProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Secrets</PageTitle>

<MudContainer MaxWidth="MaxWidth.False">
    <PageHeading Text="Secrets" />

    <MudTable @ref="_table" T="SecretModel" ServerData="ServerReload" Dense="true" Hover="true" Elevation="0" RowStyle="cursor: pointer;" OnRowClick="OnRowClick">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" DebounceInterval="250" OnDebounceIntervalElapsed="ReloadAsync" />
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateAsync">Create Secret</MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Store</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Version</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudText Typo="Typo.body2">@context.DisplayName</MudText>
                <MudText Typo="Typo.caption">@context.Name</MudText>
            </MudTd>
            <MudTd DataLabel="Type">@context.TypeName</MudTd>
            <MudTd DataLabel="Store">@context.StoreName</MudTd>
            <MudTd DataLabel="Status"><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@context.Status</MudChip></MudTd>
            <MudTd DataLabel="Version">@context.CurrentVersion</MudTd>
            <MudTd>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true">
                    <MudMenuItem OnClick="@(() => RotateAsync(context))">Rotate</MudMenuItem>
                    <MudMenuItem OnClick="@(() => TestAsync(context))">Test</MudMenuItem>
                    <MudMenuItem OnClick="@(() => RevokeAsync(context))">Revoke</MudMenuItem>
                    <MudMenuItem OnClick="@(() => DeleteAsync(context))">Delete</MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No secrets found</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private MudTable<SecretModel> _table = default!;
    private SecretDescriptorsResponse _descriptors = new();
    private string? _search;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var api = await GetApiAsync();
            _descriptors = await api.GetDescriptorsAsync();
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private async Task<ISecretsApi> GetApiAsync() => await ApiClientProvider.GetApiAsync<ISecretsApi>();

    private async Task ReloadAsync()
    {
        await _table.ReloadServerData();
    }

    private async Task<TableData<SecretModel>> ServerReload(TableState state, CancellationToken cancellationToken)
    {
        try
        {
            var api = await GetApiAsync();
            var response = await api.ListAsync(search: _search, page: state.Page, pageSize: state.PageSize, cancellationToken: cancellationToken);

            return new TableData<SecretModel>
            {
                Items = response.Items,
                TotalItems = response.TotalCount > int.MaxValue ? int.MaxValue : (int)response.TotalCount
            };
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
            return new TableData<SecretModel> { Items = [], TotalItems = 0 };
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
            return new TableData<SecretModel> { Items = [], TotalItems = 0 };
        }
    }

    private void OnRowClick(TableRowClickEventArgs<SecretModel> args)
    {
        if (args.Item != null)
            NavigationManager.NavigateTo($"security/secrets/{Uri.EscapeDataString(args.Item.Name)}");
    }

    private async Task CreateAsync()
    {
        var parameters = new DialogParameters<CreateSecretDialog> { { x => x.Descriptors, _descriptors } };
        var options = new DialogOptions { CloseOnEscapeKey = true, CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Small };
        var dialog = await DialogService.ShowAsync<CreateSecretDialog>("Create Secret", parameters, options);
        var result = await dialog.Result;
        if (result is not { Canceled: false, Data: CreateSecretRequest request })
            return;

        try
        {
            var api = await GetApiAsync();
            var created = await api.CreateAsync(request);
            Snackbar.Add("Secret created.", Severity.Success);
            NavigationManager.NavigateTo($"security/secrets/{Uri.EscapeDataString(created.Name)}");
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private async Task RotateAsync(SecretModel secret)
    {
        var value = await DialogService.ShowMessageBoxAsync("Rotate secret", "Enter the replacement value on the detail page.", yesText: "Open", cancelText: "Cancel");
        if (value == true)
            NavigationManager.NavigateTo($"security/secrets/{Uri.EscapeDataString(secret.Name)}");
    }

    private async Task TestAsync(SecretModel secret)
    {
        try
        {
            var api = await GetApiAsync();
            var result = await api.TestAsync(secret.Name);
            Snackbar.Add(result.Succeeded ? "Secret resolved successfully." : result.Error ?? "Secret test failed.", result.Succeeded ? Severity.Success : Severity.Error);
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private async Task RevokeAsync(SecretModel secret)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync("Revoke secret?", $"Revoke {secret.DisplayName}?", yesText: "Revoke", cancelText: "Cancel");
        if (confirmed != true)
            return;

        try
        {
            var api = await GetApiAsync();
            await api.RevokeAsync(secret.Name);
            await ReloadAsync();
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private async Task DeleteAsync(SecretModel secret)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync("Delete secret?", $"Delete {secret.DisplayName}?", yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true)
            return;

        try
        {
            var api = await GetApiAsync();
            await api.DeleteAsync(secret.Name);
            Snackbar.Add("Secret deleted.", Severity.Success);
            await ReloadAsync();
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private static Color StatusColor(SecretStatus status) => status switch
    {
        SecretStatus.Active => Color.Success,
        SecretStatus.Revoked => Color.Error,
        SecretStatus.Expired => Color.Warning,
        _ => Color.Default
    };
}
