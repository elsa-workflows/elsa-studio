@page "/security/secrets/{Name}"
@using System.Globalization
@using Elsa.Studio.Contracts
@using Elsa.Studio.Secrets.Client
@inject IBackendApiClientProvider ApiClientProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Secret</PageTitle>

<style>
    .secret-container.mud-container {
        padding-left: 0;
        padding-right: 0;
    }

    .secret-page {
        background:
            linear-gradient(180deg, color-mix(in srgb, var(--mud-palette-primary, #0ea5e9) 6%, var(--mud-palette-background, #ffffff)) 0, var(--mud-palette-background, #ffffff) 25rem);
        min-height: calc(100vh - var(--mud-appbar-height, 64px));
        overflow-x: hidden;
        padding: 1.5rem 2rem 3rem;
    }

    .secret-loading {
        align-items: center;
        display: flex;
        justify-content: center;
        min-height: 16rem;
    }

    .secret-alert {
        margin: 1.5rem 0;
    }

    .secret-hero,
    .secret-panel {
        background: var(--mud-palette-surface, #ffffff);
        border-radius: 8px;
        box-sizing: border-box;
    }

    .secret-hero {
        border: 1px solid color-mix(in srgb, var(--mud-palette-primary, #0ea5e9) 18%, var(--mud-palette-lines-default, #d7dde5));
        box-shadow: 0 18px 42px rgba(15, 23, 42, .07);
        overflow: hidden;
        padding: 1.25rem 1.35rem;
        position: relative;
    }

    .secret-hero::before {
        background: linear-gradient(180deg, var(--mud-palette-primary, #0ea5e9), color-mix(in srgb, var(--mud-palette-primary, #0ea5e9) 52%, #14b8a6));
        bottom: 0;
        content: "";
        left: 0;
        position: absolute;
        top: 0;
        width: 4px;
    }

    .secret-hero-content,
    .secret-chip-row,
    .secret-title-group {
        flex-wrap: wrap;
    }

    .secret-title-group {
        flex: 1 1 20rem;
        min-width: 0;
    }

    .secret-title-group > div:last-child {
        min-width: 0;
    }

    .secret-icon-shell {
        align-items: center;
        background: color-mix(in srgb, var(--mud-palette-primary, #0ea5e9) 14%, var(--mud-palette-surface, #ffffff));
        border: 1px solid color-mix(in srgb, var(--mud-palette-primary, #0ea5e9) 25%, transparent);
        border-radius: 8px;
        color: var(--mud-palette-primary, #0ea5e9);
        display: flex;
        height: 3rem;
        justify-content: center;
        width: 3rem;
    }

    .secret-title {
        line-height: 1.15;
        overflow-wrap: anywhere;
    }

    .secret-technical-name {
        color: var(--mud-palette-text-secondary, #5f6b7a);
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        overflow-wrap: anywhere;
    }

    .secret-panel {
        padding: 1.25rem;
    }

    .secret-description {
        background: color-mix(in srgb, var(--mud-palette-primary, #0ea5e9) 4%, var(--mud-palette-surface, #ffffff));
        border: 1px solid color-mix(in srgb, var(--mud-palette-primary, #0ea5e9) 12%, var(--mud-palette-lines-default, #d7dde5));
        border-radius: 8px;
        box-sizing: border-box;
        max-width: 100%;
        overflow-wrap: anywhere;
        padding: .9rem 1rem;
    }

    .secret-label,
    .secret-data-item span {
        color: var(--mud-palette-text-secondary, #5f6b7a);
        font-weight: 650;
        letter-spacing: .02em;
        text-transform: uppercase;
    }

    .secret-data-grid {
        display: grid;
        gap: 0 1.5rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .secret-data-item {
        border-bottom: 1px solid var(--mud-palette-lines-default, #d7dde5);
        display: grid;
        gap: .3rem;
        min-width: 0;
        padding: .85rem 0;
    }

    .secret-data-item strong {
        font-weight: 600;
        overflow-wrap: anywhere;
    }

    .secret-action-panel {
        border-color: color-mix(in srgb, var(--mud-palette-primary, #0ea5e9) 18%, var(--mud-palette-lines-default, #d7dde5)) !important;
    }

    .secret-danger-panel {
        border-color: color-mix(in srgb, var(--mud-palette-error, #f44336) 30%, var(--mud-palette-lines-default, #d7dde5)) !important;
    }

    @@media (max-width: 64rem) {
        .secret-page {
            padding: 1rem;
        }

        .secret-data-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 40rem) {
        .secret-page {
            padding: 1rem;
        }

        .secret-main-grid {
            margin: 0 !important;
            width: 100% !important;
        }

        .secret-main-grid > .mud-grid-item {
            padding-left: 0 !important;
            padding-top: 1rem !important;
        }

        .secret-hero,
        .secret-panel {
            padding: 1rem;
        }

        .secret-icon-shell {
            height: 2.5rem;
            width: 2.5rem;
        }

        .secret-title {
            font-size: 1.55rem;
            line-height: 1.2;
        }

        .secret-chip-row {
            justify-content: flex-start !important;
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.False" Class="secret-container">
    <div class="secret-page">
        @if (_secret == null)
        {
            @if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="secret-alert">@_loadError</MudAlert>
            }
            else
            {
                <div class="secret-loading">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
        }
        else
        {
            <MudStack Spacing="4">
                <MudPaper Class="secret-hero" Elevation="0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="4" Class="secret-hero-content">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="secret-title-group">
                            <div class="secret-icon-shell">
                                <MudIcon Icon="@Icons.Material.Outlined.Key" Size="Size.Medium" />
                            </div>
                            <div>
                                <MudText Typo="Typo.h4" Class="secret-title">@_secret.DisplayName</MudText>
                                <MudText Typo="Typo.body2" Class="secret-technical-name">@_secret.Name</MudText>
                            </div>
                        </MudStack>

                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1" Class="secret-chip-row">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(_secret.Status)">@_secret.Status</MudChip>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@_secret.TypeName</MudChip>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_secret.StoreName</MudChip>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Version @VersionText</MudChip>
                        </MudStack>
                    </MudStack>
                </MudPaper>

                <MudGrid Spacing="4" Class="secret-main-grid">
                    <MudItem xs="12" lg="8">
                        <MudPaper Class="secret-panel" Elevation="0" Outlined="true">
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Outlined.AdminPanelSettings" Size="Size.Small" Color="Color.Primary" />
                                        <MudText Typo="Typo.h6">Secret profile</MudText>
                                    </MudStack>
                                    @if (!_isEditingDetails)
                                    {
                                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Outlined.Edit" OnClick="StartEditingDetails">Edit details</MudButton>
                                    }
                                </MudStack>

                                @if (_isEditingDetails)
                                {
                                    <MudStack Spacing="2">
                                        <MudTextField @bind-Value="_details.DisplayName" Label="Display name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                        <MudTextField @bind-Value="_details.Description" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                                        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
                                            <MudButton Variant="Variant.Text" OnClick="CancelEditingDetails" Disabled="@_isSavingDetails">Cancel</MudButton>
                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveDetailsAsync" Disabled="@_isSavingDetails">
                                                @(_isSavingDetails ? "Saving..." : "Save details")
                                            </MudButton>
                                        </MudStack>
                                    </MudStack>
                                }
                                else
                                {
                                    <div class="secret-description">
                                        <MudText Typo="Typo.caption" Class="secret-label">Description</MudText>
                                        <MudText Typo="Typo.body2">@ValueOrDash(_secret.Description)</MudText>
                                    </div>
                                }

                                <div class="secret-data-grid">
                                    <div class="secret-data-item">
                                        <span>Technical name</span>
                                        <strong>@_secret.Name</strong>
                                    </div>
                                    <div class="secret-data-item">
                                        <span>Display name</span>
                                        <strong>@_secret.DisplayName</strong>
                                    </div>
                                    <div class="secret-data-item">
                                        <span>Type</span>
                                        <strong>@_secret.TypeName</strong>
                                    </div>
                                    <div class="secret-data-item">
                                        <span>Store</span>
                                        <strong>@_secret.StoreName</strong>
                                    </div>
                                    <div class="secret-data-item">
                                        <span>Status</span>
                                        <strong>@_secret.Status</strong>
                                    </div>
                                    <div class="secret-data-item">
                                        <span>Current version</span>
                                        <strong>@VersionText</strong>
                                    </div>
                                    <div class="secret-data-item">
                                        <span>Scope</span>
                                        <strong>@ValueOrDash(_secret.Scope)</strong>
                                    </div>
                                    <div class="secret-data-item">
                                        <span>Created</span>
                                        <strong>@FormatDateTime(_secret.CreatedAt)</strong>
                                    </div>
                                    <div class="secret-data-item">
                                        <span>Updated</span>
                                        <strong>@FormatDateTime(_secret.UpdatedAt)</strong>
                                    </div>
                                    <div class="secret-data-item">
                                        <span>Expires</span>
                                        <strong>@FormatDateTime(_secret.ExpiresAt)</strong>
                                    </div>
                                </div>
                            </MudStack>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" lg="4">
                        <MudStack Spacing="4">
                            <MudPaper Class="secret-panel secret-action-panel" Elevation="0" Outlined="true">
                                <MudStack Spacing="3">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Outlined.Autorenew" Size="Size.Small" Color="Color.Primary" />
                                        <MudText Typo="Typo.h6">Rotate secret</MudText>
                                    </MudStack>

                                    @if (_secret.StoreName == SecretStoreNames.Configuration)
                                    {
                                        <MudTextField @bind-Value="_rotation.ConfigurationKey" Label="Replacement configuration key" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    }
                                    else
                                    {
                                        <MudTextField @bind-Value="_rotation.Value" Label="Replacement value" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    }

                                    <MudGrid Spacing="2">
                                        <MudItem xs="12" sm="7">
                                            <MudDatePicker @bind-Date="_rotationExpiresDate"
                                                           Label="Expires at"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Clearable="true"
                                                           Editable="true"
                                                           DateFormat="@CultureInfo.CurrentCulture.DateTimeFormat.ShortDatePattern" />
                                        </MudItem>
                                        <MudItem xs="12" sm="5">
                                            <MudTimePicker @bind-Time="_rotationExpiresTime"
                                                           Label="Time"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Clearable="true"
                                                           Editable="true"
                                                           Disabled="@(_rotationExpiresDate == null)"
                                                           TimeFormat="@CultureInfo.CurrentCulture.DateTimeFormat.ShortTimePattern" />
                                        </MudItem>
                                    </MudGrid>

                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Autorenew" OnClick="RotateAsync" FullWidth="true">Rotate Secret</MudButton>
                                </MudStack>
                            </MudPaper>

                            <MudPaper Class="secret-panel secret-danger-panel" Elevation="0" Outlined="true">
                                <MudStack Spacing="3">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Outlined.Block" Size="Size.Small" Color="Color.Error" />
                                        <MudText Typo="Typo.h6">Danger zone</MudText>
                                    </MudStack>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Block" OnClick="RevokeAsync" FullWidth="true">Revoke Secret</MudButton>
                                </MudStack>
                            </MudPaper>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudStack>
        }
    </div>
</MudContainer>

@code {
    private SecretModel? _secret;
    private readonly RotateSecretRequest _rotation = new();
    private readonly UpdateSecretRequest _details = new();
    private string? _loadedName;
    private string? _loadError;
    private DateTime? _rotationExpiresDate;
    private TimeSpan? _rotationExpiresTime;
    private bool _isEditingDetails;
    private bool _isSavingDetails;

    [Parameter] public string Name { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        var name = Uri.UnescapeDataString(Name);
        if (string.Equals(_loadedName, name, StringComparison.Ordinal))
            return;

        _loadedName = name;
        _secret = null;
        _loadError = null;
        _isEditingDetails = false;
        _isSavingDetails = false;
        _rotation.Value = null;
        _rotation.ConfigurationKey = null;
        ClearRotationExpiration();
        SyncDetailsModel();

        try
        {
            var api = await ApiClientProvider.GetApiAsync<ISecretsApi>();
            _secret = await api.GetAsync(name);
            SyncDetailsModel();
        }
        catch (Exception e)
        {
            _loadedName = null;
            _loadError = e.Message;
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private void StartEditingDetails()
    {
        SyncDetailsModel();
        _isEditingDetails = true;
    }

    private void CancelEditingDetails()
    {
        SyncDetailsModel();
        _isEditingDetails = false;
    }

    private async Task SaveDetailsAsync()
    {
        if (_secret == null)
            return;

        try
        {
            _isSavingDetails = true;
            var api = await ApiClientProvider.GetApiAsync<ISecretsApi>();
            _secret = await api.UpdateAsync(_secret.Name, _details);
            SyncDetailsModel();
            _isEditingDetails = false;
            Snackbar.Add("Secret details updated.", Severity.Success);
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
        finally
        {
            _isSavingDetails = false;
        }
    }

    private void SyncDetailsModel()
    {
        _details.DisplayName = _secret?.DisplayName;
        _details.Description = _secret?.Description;
    }

    private async Task RotateAsync()
    {
        if (_secret == null)
            return;

        try
        {
            var api = await ApiClientProvider.GetApiAsync<ISecretsApi>();
            _rotation.ExpiresAt = CreateRotationExpiresAt();
            _secret = await api.RotateAsync(_secret.Name, _rotation);
            _rotation.Value = null;
            _rotation.ConfigurationKey = null;
            _rotation.ExpiresAt = null;
            ClearRotationExpiration();
            Snackbar.Add("Secret rotated.", Severity.Success);
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private async Task RevokeAsync()
    {
        if (_secret == null)
            return;

        var confirmed = await DialogService.ShowMessageBoxAsync("Revoke secret?", $"Revoke {_secret.DisplayName}?", yesText: "Revoke", cancelText: "Cancel");
        if (confirmed != true)
            return;

        try
        {
            var api = await ApiClientProvider.GetApiAsync<ISecretsApi>();
            _secret = await api.RevokeAsync(_secret.Name);
            Snackbar.Add("Secret revoked.", Severity.Warning);
            StateHasChanged();
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private string VersionText => _secret?.CurrentVersion?.ToString() ?? "-";

    private DateTimeOffset? CreateRotationExpiresAt()
    {
        if (_rotationExpiresDate == null)
            return null;

        var localDateTime = DateTime.SpecifyKind(_rotationExpiresDate.Value.Date.Add(_rotationExpiresTime ?? TimeSpan.Zero), DateTimeKind.Unspecified);
        return new DateTimeOffset(localDateTime, TimeZoneInfo.Local.GetUtcOffset(localDateTime));
    }

    private void ClearRotationExpiration()
    {
        _rotationExpiresDate = null;
        _rotationExpiresTime = null;
    }

    private static string ValueOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDateTime(DateTimeOffset value) => value == default ? "-" : value.ToLocalTime().ToString("g");

    private static string FormatDateTime(DateTimeOffset? value) => value.HasValue ? FormatDateTime(value.Value) : "-";

    private static Color StatusColor(SecretStatus status) => status switch
    {
        SecretStatus.Active => Color.Success,
        SecretStatus.Revoked or SecretStatus.Deleted => Color.Error,
        SecretStatus.Expired or SecretStatus.Retired => Color.Warning,
        _ => Color.Default
    };
}
