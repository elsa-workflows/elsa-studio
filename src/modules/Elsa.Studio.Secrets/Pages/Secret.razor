@page "/security/secrets/{Name}"
@using Elsa.Studio.Contracts
@using Elsa.Studio.Secrets.Client
@inject IBackendApiClientProvider ApiClientProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Secret</PageTitle>

<MudContainer MaxWidth="MaxWidth.False">
    @if (_secret == null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <PageHeading Text="@_secret.DisplayName" />
        <MudGrid>
            <MudItem xs="12" md="7">
                <MudPaper Class="pa-6" Elevation="0" Outlined="true">
                    <MudStack Spacing="4">
                        <MudTextField Value="_secret.Name" Label="Technical name" ReadOnly="true" Variant="Variant.Outlined" />
                        <MudTextField Value="_secret.DisplayName" Label="Display name" ReadOnly="true" Variant="Variant.Outlined" />
                        <MudTextField Value="_secret.Description" Label="Description" ReadOnly="true" Lines="3" Variant="Variant.Outlined" />
                        <MudGrid>
                            <MudItem xs="12" sm="6"><MudTextField Value="_secret.TypeName" Label="Type" ReadOnly="true" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12" sm="6"><MudTextField Value="_secret.StoreName" Label="Store" ReadOnly="true" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12" sm="6"><MudTextField Value="_secret.Status.ToString()" Label="Status" ReadOnly="true" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12" sm="6"><MudTextField Value="_secret.CurrentVersion?.ToString()" Label="Current version" ReadOnly="true" Variant="Variant.Outlined" /></MudItem>
                        </MudGrid>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="5">
                <MudPaper Class="pa-6" Elevation="0" Outlined="true">
                    <MudStack Spacing="4">
                        <MudText Typo="Typo.h6">Rotate</MudText>
                        @if (_secret.StoreName == SecretStoreNames.Configuration)
                        {
                            <MudTextField @bind-Value="_rotation.ConfigurationKey" Label="Replacement configuration key" Variant="Variant.Outlined" />
                        }
                        else
                        {
                            <MudTextField @bind-Value="_rotation.Value" Label="Replacement value" InputType="InputType.Password" Variant="Variant.Outlined" />
                        }
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Autorenew" OnClick="RotateAsync">Rotate Secret</MudButton>
                        <MudDivider />
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Block" OnClick="RevokeAsync">Revoke Secret</MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private SecretModel? _secret;
    private readonly RotateSecretRequest _rotation = new();

    [Parameter] public string Name { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            var api = await ApiClientProvider.GetApiAsync<ISecretsApi>();
            _secret = await api.GetAsync(Uri.UnescapeDataString(Name));
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private async Task RotateAsync()
    {
        if (_secret == null)
            return;

        try
        {
            var api = await ApiClientProvider.GetApiAsync<ISecretsApi>();
            _secret = await api.RotateAsync(_secret.Name, _rotation);
            _rotation.Value = null;
            _rotation.ConfigurationKey = null;
            Snackbar.Add("Secret rotated.", Severity.Success);
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private async Task RevokeAsync()
    {
        if (_secret == null)
            return;

        var confirmed = await DialogService.ShowMessageBoxAsync("Revoke secret?", $"Revoke {_secret.DisplayName}?", yesText: "Revoke", cancelText: "Cancel");
        if (confirmed != true)
            return;

        try
        {
            var api = await ApiClientProvider.GetApiAsync<ISecretsApi>();
            _secret = await api.RevokeAsync(_secret.Name);
            Snackbar.Add("Secret revoked.", Severity.Warning);
            StateHasChanged();
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }
}
