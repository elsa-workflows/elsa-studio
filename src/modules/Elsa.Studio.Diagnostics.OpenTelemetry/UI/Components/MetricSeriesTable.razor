@using Elsa.Studio.Diagnostics.OpenTelemetry.Services

@if (Rows.Count == 0)
{
    <div class="elsa-otel-state">No metrics received.</div>
}
else
{
    <table class="elsa-otel-table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Kind</th>
            <th>Unit</th>
            <th>Points</th>
            <th>Last Value</th>
            <th>Last Sum</th>
            <th>Last Count</th>
            <th>Last Timestamp</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var row in Rows)
        {
            <tr>
                <td>@row.Instrument.Name</td>
                <td>@row.Instrument.Kind</td>
                <td>@(row.Instrument.Unit ?? "-")</td>
                <td>@row.PointCount</td>
                <td>@FormatNumber(row.LastValue)</td>
                <td>@FormatNumber(row.LastSum)</td>
                <td>@(row.LastCount?.ToString() ?? "-")</td>
                <td>@(row.LastTimestamp.HasValue ? FormatTime(row.LastTimestamp.Value) : "-")</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    [Parameter] public OpenTelemetryMetricResult Metrics { get; set; } = new([], [], 0);

    private IReadOnlyCollection<MetricSeriesRow> Rows => MetricSeriesMapper.CreateRows(Metrics);

    private static string FormatNumber(double? value) => value?.ToString("n2") ?? "-";

    private static string FormatTime(DateTimeOffset value) => value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
}
